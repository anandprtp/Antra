# ─── Antra Configuration ──────────────────────────────────

# Spotify Integration (optional)
# Get your Client ID at developer.spotify.com
SPOTIFY_CLIENT_ID=

# YAMS Integration (optional)
# Log in at yams.tf and extract your session token
YAMS_AUTH_TOKEN=

# Output directory (optional, defaults to ~/Music)
ANTRA_OUTPUT_DIR=
