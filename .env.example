# ─── Antra Configuration ──────────────────────────────────

# Spotify Integration (optional)
# Get your Client ID at developer.spotify.com
SPOTIFY_CLIENT_ID=

# YAMS Integration (optional)
# Log in at yams.tf and extract your session token
YAMS_AUTH_TOKEN=

# Output directory (optional, defaults to ~/Music)
ANTRA_OUTPUT_DIR=

# ─── Private Endpoint Manifest ────────────────────────────────────────────────
# Points Antra to your self-hosted mirror servers without hardcoding URLs.
# The manifest is a JSON file served at a secret path only you know.
#
# Setup:
#   1. Copy API-Mirrors/tidal_api/manifest.json.template → manifest.json
#   2. Fill in your actual mirror URLs
#   3. Set MANIFEST_SECRET=<random-string> in the tidal server's environment
#   4. Set the URL below to: https://your-manifest-host.example/manifest/<same-secret>
#
# The secret path is unguessable — nobody can discover your mirror URLs
# even if they know the manifest endpoint exists.
ANTRA_ENDPOINT_MANIFEST_URL=

# ─── Mirror URL overrides (optional — manifest takes care of this normally) ───
# Only set these if you want to override what the manifest provides,
# or if you're running locally without a manifest server.
# TIDAL_MIRROR_URL=http://localhost:7338
# QOBUZ_MIRROR_URL=http://localhost:7343
# DEEZER_MIRROR_URL=http://localhost:7342
